{
  "$schema": "./docs/skills.schema.json",
  "version": 1,
  "tool": {
    "name": "gflow-cli",
    "install": "npm install -g @swissmarley/gflow-cli",
    "description": "CLI automation for Google Flow (image/video generation)."
  },
  "skills": [
    {
      "name": "character-pipeline",
      "version": "1.0.0",
      "foundation": true,
      "description": "Create consistent, reusable characters with defined visual identity, personality and voice.",
      "tags": ["foundation", "character", "identity"],
      "commands": [{ "file": "commands/character.md", "slash": "character" }],
      "triggers": [
        { "phrase": "create a character", "kind": "activation" },
        { "phrase": "character design", "kind": "activation" }
      ]
    },
    {
      "name": "brand-identity",
      "version": "1.0.0",
      "foundation": true,
      "description": "Establish a complete brand visual system and configure a Flow project for consistent downstream generation.",
      "tags": ["foundation", "brand", "identity"],
      "commands": [{ "file": "commands/brand.md", "slash": "brand" }],
      "triggers": [
        { "phrase": "brand identity", "kind": "activation" },
        { "phrase": "brand system", "kind": "activation" }
      ]
    },
    {
      "name": "immersive-web",
      "version": "1.0.0",
      "foundation": false,
      "consumes": ["brand-identity", "character-pipeline"],
      "description": "Build cinematic, scroll-driven websites with AI-generated imagery and video loops.",
      "tags": ["web", "3d", "scroll", "motion"],
      "commands": [{ "file": "commands/immersive.md", "slash": "immersive" }],
      "triggers": [
        { "phrase": "immersive website", "kind": "activation" },
        { "phrase": "scroll-driven site", "kind": "activation" },
        { "phrase": "3d parallax website", "kind": "activation" }
