{
  "$schema": "./skills.schema.json",
  "version": 1,
  "tool": {
    "name": "gflow-cli",
    "install": "npm install -g @swissmarley/gflow-cli",
    "description": "CLI automation for Google Flow (image/video generation)."
  },
  "skills": [
    {
      "name": "character-pipeline",
      "version": "1.0.0",
      "foundation": true,
      "description": "Create consistent, reusable characters with defined visual identity, personality and voice.",
      "tags": ["foundation", "character", "identity"],
      "commands": [{ "file": "commands/gflow-character.md", "slash": "gflow-character" }],
      "triggers": [
        { "phrase": "create a character", "kind": "activation" },
        { "phrase": "character design", "kind": "activation" }
      ]
    },
    {
      "name": "brand-identity",
      "version": "1.0.0",
      "foundation": true,
      "description": "Establish a complete brand visual system and configure a Flow project for consistent downstream generation.",
